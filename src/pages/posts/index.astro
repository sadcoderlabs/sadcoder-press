---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const lang = 'en';

const posts = (await getCollection('posts', ({ data }) => data.lang === lang && !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Posts" lang={lang}>
  <h1 class="text-3xl font-bold mt-8 mb-6">Posts</h1>
  {posts.length === 0 && <p class="text-gray-500 dark:text-gray-400">No posts yet.</p>}
  <ul class="space-y-6">
    {posts.map((post) => (
      <li>
        <a href={`/posts/${post.id.replace(/^en\//, '')}/`} class="text-xl text-blue-600 dark:text-blue-400 hover:underline">{post.data.title}</a>
        <span class="text-sm text-gray-500 dark:text-gray-400 ml-2">{post.data.date.toLocaleDateString('en-US')}</span>
        <div class="flex gap-1 mt-2">
          {post.data.platform.map((p) => (
            <span class="text-xs bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 px-2 py-0.5 rounded">{p}</span>
          ))}
        </div>
        <div class="flex gap-1 mt-1">
          {post.data.tags.map((tag) => (
            <span class="text-xs bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 px-2 py-0.5 rounded">{tag}</span>
          ))}
        </div>
      </li>
    ))}
  </ul>
</Base>
