---
import Base from '../../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { getSlug } from '../../../lib/utils';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => data.lang === 'zh' && !data.draft);
  return posts.map((post) => ({
    params: { slug: getSlug(post.id) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={post.data.title} lang="zh">
  <article class="mt-8">
    <h1 class="text-3xl font-bold mb-2">{post.data.title}</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">{post.data.date.toLocaleDateString('zh-TW')}</p>
    <div class="flex gap-1 mb-4">
      {post.data.platform.map((p) => (
        <span class="text-xs bg-blue-900 dark:bg-blue-900/50 text-blue-700 dark:text-blue-300 px-2 py-0.5 rounded">{p}</span>
      ))}
    </div>
    <div class="prose max-w-none mb-6">
      <Content />
    </div>
    {post.data.publishedUrl && (
      <div class="border-t dark:border-gray-700 pt-4 mt-6">
        <h2 class="text-sm font-semibold text-gray-500 dark:text-gray-400 mb-2">發布於</h2>
        <div class="flex gap-3">
          {Object.entries(post.data.publishedUrl).map(([platform, url]) => (
            <a href={url} target="_blank" rel="noopener noreferrer" class="text-blue-600 dark:text-blue-400 hover:underline text-sm capitalize">
              {platform}
            </a>
          ))}
        </div>
      </div>
    )}
  </article>
</Base>
