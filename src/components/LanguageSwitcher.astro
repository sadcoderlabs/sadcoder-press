---
const { lang } = Astro.props;
const currentPath = Astro.url.pathname;

function getAlternatePath(path: string, currentLang: string): string {
  if (currentLang === 'en') {
    return `/zh${path}`;
  }
  return path.replace(/^\/zh/, '') || '/';
}

const alternateLang = lang === 'en' ? 'zh' : 'en';
const alternatePath = getAlternatePath(currentPath, lang);
const label = lang === 'en' ? '中文' : 'English';
---

<a href={alternatePath} class="text-sm transition-colors" style="color: var(--brand-primary-text);">
  {label}
</a>
